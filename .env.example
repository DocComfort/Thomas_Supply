# Thomas Supply Dealer Portal
# Copy this file to apps/web/.env.local for local dev, and set the same keys in
# Vercel Project Settings -> Environment Variables for production.

# Public marketing-site link to the dealer portal. Local MVP default is
# http://localhost:3010/login.
NEXT_PUBLIC_DEALER_PORTAL_URL=

# Public portal link back to the main Thomas Supply marketing site. Local
# default is http://localhost:3000.
NEXT_PUBLIC_MARKETING_SITE_URL=

# Odoo remains the source of truth. When any of these are blank, the app uses
# mock Odoo responses from packages/odoo/mock-data.ts.
ODOO_BASE_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=

# PostgreSQL connection used by Prisma in production. The MVP UI can run with
# in-memory demo data when DATABASE_URL is blank.
DATABASE_URL=

# Used by the local auth abstraction to sign/guard sessions in later hardening.
AUTH_SECRET=replace-me-in-production

# Demo auth is disabled in production unless this is explicitly set. Prefer a
# real provider before public launch.
ALLOW_DEMO_AUTH=false

# Optional Redis-compatible cache URL. The current scaffold has an in-process
# cache placeholder and is ready to swap to Redis.
REDIS_URL=

# Production fails closed when Odoo credentials are missing. Set this only for
# intentionally mocked preview environments.
ODOO_ALLOW_MOCK=false

# Existing public website contact form settings, retained for compatibility.
RESEND_API_KEY=
CONTACT_TO_EMAIL=sales@thomassupply.net
CONTACT_FROM_EMAIL=onboarding@resend.dev
